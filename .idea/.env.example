# =============================================================================
# ARCHIVO .env — CREDENCIALES Y CONFIGURACIÓN SENSIBLE
# =============================================================================
#
# ¿QUÉ ES ESTE ARCHIVO?
# Este archivo contiene todos los valores secretos del proyecto: contraseñas,
# claves de cifrado, configuración de base de datos, etc.
#
# REGLAS IMPORTANTES:
#   1. NUNCA subas este archivo a Git ni a ningún repositorio.
#   2. Añade ".env" a tu archivo .gitignore (ver instrucciones abajo).
#   3. En el servidor de producción, crea este archivo manualmente.
#   4. Cada desarrollador debe tener su propia copia local.
#
# CÓMO GENERAR UNA NUEVA SECRET_KEY:
#   Abre una terminal Python y ejecuta:
#     import secrets
#     print(secrets.token_hex(32))
#   Copia el resultado y pégalo en JWT_SECRET_KEY.
#
# =============================================================================


# --- BASE DE DATOS -----------------------------------------------------------
# Host donde está corriendo MySQL. "127.0.0.1" = mismo servidor que el backend.
DB_HOST=

# Nombre de la base de datos a la que se conecta la app.
DB_NAME=

# Usuario de MySQL.
DB_USER=

# Contraseña de MySQL. Cámbiala si en algún momento rotas credenciales.
DB_PASSWORD=

# Puerto de MySQL. El puerto por defecto es 3306.
DB_PORT=


# --- JWT (JSON Web Tokens) ---------------------------------------------------
# Clave secreta con la que se firman y verifican todos los tokens de sesión.
#
# ⚠️  IMPORTANTE: Este valor ya ha sido generado de forma segura con
#     secrets.token_hex(32). NO lo cambies en producción sin coordinar
#     con el equipo, ya que TODOS los tokens existentes quedarán invalidados
#     y todos los usuarios tendrán que volver a hacer login.
#
# Si necesitas rotar esta clave (por ejemplo, si sospechas que se filtró),
# genera un nuevo valor con secrets.token_hex(32) y reinicia el servidor.
JWT_SECRET_KEY=REEMPLAZA_ESTO_CON_TU_CLAVE_GENERADA

# Algoritmo de firma. HS256 es el estándar para la mayoría de casos.
# No cambies esto salvo que tengas un motivo específico.
JWT_ALGORITHM=HS256

# Duración de los tokens en minutos.
# 525600 = 365 días (1 año). Ajusta según tu política de seguridad.
# Para mayor seguridad, considera reducirlo a 1440 (24 horas) o 10080 (7 días).
JWT_EXPIRE_MINUTES=525600


# --- CORS (orígenes permitidos) ----------------------------------------------
# Lista de dominios que tienen permiso para llamar a la API desde el navegador.
# Separa múltiples valores con comas SIN espacios.
# Ejemplo con varios orígenes: http://localhost:5500,https://tudominio.com
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://212.227.147.252:5500